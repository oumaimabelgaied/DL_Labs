      ],
      "source": [
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Chargement du dataset\n",
        "movie_reviews = pd.read_csv('IMDB Dataset.csv')\n",
        "\n",
        "# 1. Dimension\n",
        "print(\"Dimension:\", movie_reviews.shape)\n",
        "\n",
        "# 2. Valeurs NULL\n",
        "print(\"\\nValeurs NULL:\\n\", movie_reviews.isnull().sum())\n",
        "\n",
        "# 3. Les 5 premières lignes\n",
        "print(\"\\n5 premières lignes:\")\n",
        "print(movie_reviews.head())\n",
        "\n",
        "# 4. Distribution des classes\n",
        "sns.countplot(x='sentiment', data=movie_reviews)\n",
        "plt.title('Distribution des sentiments')\n",
        "plt.show()\n",
        "\n",
        "# 5. Le 4ème review\n",
        "print('\\n',movie_reviews['review'][3])\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "PT-ZiXMUeUxn"
      },
      "source": [
        "on remarque la présence de balise html ce qui ne sert pas du tout à déterminer le sentiment de la personne qui a écrit le review (donée superflue) !!! c'est pourquoi on procède au pré-traitement next"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "9tOxWFTiepCR"
      },
      "source": [
        "Prétraitement de données :"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {
        "id": "OItj4cnEevdj"
      },
      "outputs": [],
      "source": [
        "def preprocess_text(sen):\n",
        "  # Removing html tags\n",
        "  sentence = remove_tags(sen)\n",
        "  # Remove punctuations and numbers\n",
        "  sentence = re.sub('[^a-zA-Z]', ' ', sentence)\n",
        "  # Single character removal\n",
        "  sentence = re.sub(r\"\\s+[a-zA-Z]\\s+\", ' ', sentence)\n",
        "  # Removing multiple spaces\n",
        "  sentence = re.sub(r'\\s+', ' ', sentence)\n",
        "  return sentence\n",
        "TAG_RE = re.compile(r'<[^>]+>')\n",
        "def remove_tags(text):\n",
        "  return TAG_RE.sub('', text)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "rrwdXbmVe19W"
      },
      "source": [
        "La fonction remove_tags utilise une expression régulière r'<[^>]+>' pour détecter et supprimer toutes les balises HTML .\n",
        "La fonction preprocess_text applique ensuite 4 étapes de nettoyage. D'abord elle élimine les balises HTML. Ensuite, elle utilise re.sub('[^a-zA-Z]', ' ', sentence) pour remplacer tout ce qui n'est pas une lettre (chiffres, ponctuation, caractères spéciaux) par un espace. Puis re.sub(r\"\\s+[a-zA-Z]\\s+\", ' ', sentence) supprime les caractères isolés d'une seule lettre entourés d'espaces, comme les articles \"a\" ou \"i\" qui n'apportent aucune information utile. Enfin, re.sub(r'\\s+', ' ', sentence) réduit tous les espaces multiples générés par les étapes précédentes en un seul espace, pour obtenir un texte propre et normalisé."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 5,
      "metadata": {
        "id": "-KReC500fKD2"
      },
      "outputs": [],
      "source": [
        "X = []\n",
        "sentences = list(movie_reviews['review'])\n",
        "for sen in sentences:\n",
        "  X.append(preprocess_text(sen))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {
        "id": "gfAqKBzZf2WG"
      },
      "outputs": [],
      "source": [
        "y = movie_reviews['sentiment']\n",
        "y = np.array(list(map(lambda x: 1 if x==\"positive\" else 0, y)))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "id": "vvywz_5Uf5aa"
      },
      "outputs": [],
      "source": [
        "X_train_raw, X_test_raw, y_train, y_test = train_test_split(X, y,\n",
        "test_size=0.20, random_state=42)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "2QsrT86ef8DH"
      },
      "source": [
        "La couche de l'embedding"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {
        "id": "gZF89tofgPYa"
      },
      "outputs": [],
      "source": [
        "tokenizer = Tokenizer(num_words=5000)\n",
        "tokenizer.fit_on_texts(X_train_raw)\n",
        "X_train = tokenizer.texts_to_sequences(X_train_raw)\n",
        "X_test = tokenizer.texts_to_sequences(X_test_raw)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "id": "zOskS14BgkcQ"
      },
      "outputs": [],
      "source": [
        "# Adding 1 because of reserved 0 index\n",
        "vocab_size = len(tokenizer.word_index) + 1\n",
        "maxlen = 100\n",
        "X_train = pad_sequences(X_train, padding='post', maxlen=maxlen)\n",
        "X_test = pad_sequences(X_test, padding='post', maxlen=maxlen)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "metadata": {
        "id": "YaBvi4OugrNx"
      },
      "outputs": [],
      "source": [
        "from numpy import array\n",
        "from numpy import asarray\n",
        "from numpy import zeros\n",
        "\n",
        "embeddings_dictionary = dict()\n",
        "glove_file = open(\"glove.6B.100d.txt\", encoding=\"utf8\")\n",
        "for line in glove_file:\n",
        "  records = line.split()\n",
        "  word = records[0]\n",
        "  vector_dimensions = asarray(records[1:],dtype='float32')\n",
        "  embeddings_dictionary [word] = vector_dimensions\n",
        "glove_file.close()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 11,
      "metadata": {
        "id": "KZgys03ihd0y"
      },
      "outputs": [],
      "source": [
        "embedding_matrix = zeros((vocab_size, 100))\n",
        "for word, index in tokenizer.word_index.items():\n",
        "    embedding_vector = embeddings_dictionary.get(word)\n",
        "    if embedding_vector is not None and len(embedding_vector) == 100:\n",
        "        embedding_matrix[index] = embedding_vector"
      ]
    },
