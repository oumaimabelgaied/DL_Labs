      "cell_type": "code",
      "execution_count": 25,
      "metadata": {
        "id": "kXVmYyhHmhhU"
      },
      "outputs": [],
      "source": [
        "# TF-IDF (pas d'Embedding layer — vecteurs directs)\n",
        "\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import accuracy_score\n",
        "\n",
        "tfidf = TfidfVectorizer(max_features=5000)\n",
        "X_train_tfidf = tfidf.fit_transform(X_train_raw)  # textes bruts avant tokenisation\n",
        "X_test_tfidf  = tfidf.transform(X_test_raw)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 26,
      "metadata": {
        "id": "oCnzC9vmml8H"
      },
      "outputs": [],
      "source": [
        "from keras.layers import GRU, Reshape\n",
        "\n",
        "def build_and_train(emb_matrix, emb_dim, classifier='lstm'):\n",
        "    model = Sequential()\n",
        "    model.add(Embedding(vocab_size, emb_dim,\n",
        "                        weights=[emb_matrix],\n",
        "                        input_length=maxlen,\n",
        "                        trainable=False))\n",
        "    if classifier == 'lstm':\n",
        "        model.add(LSTM(128))\n",
        "\n",
        "    elif classifier == 'gru':\n",
        "        model.add(GRU(128))\n",
        "\n",
        "    elif classifier == 'rnn_cnn':\n",
        "        model.add(Conv1D(64, 5, activation='relu'))\n",
        "        # ✅ LSTM avant GlobalMaxPooling1D, pas après\n",
        "        model.add(LSTM(64))\n",
        "        # ✅ Supprimé GlobalMaxPooling1D qui causait le passage en 2D\n",
        "\n",
        "    model.add(Dense(1, activation='sigmoid'))\n",
        "    model.compile(loss='binary_crossentropy', optimizer='adam', metrics=['acc'])\n",
        "    model.fit(X_train, y_train, batch_size=128, epochs=6,\n",
        "              verbose=0, validation_split=0.2)\n",
        "\n",
        "    score = model.evaluate(X_test, y_test, verbose=0)\n",
        "    return round(score[1], 4)"
      ]
    },
